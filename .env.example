# ===========================================
# LocaFleet Environment Variables
# ===========================================
# Copy to .env.local for local development.
# For Vercel deployments, set these via `vercel env add` or the dashboard
# for Production / Preview / Development environments.

# --- Supabase Database ---
# DATABASE_URL = transaction-mode pooler (port 6543) — used at runtime
# DIRECT_URL   = session-mode pooler  (port 5432) — used by drizzle-kit migrations
# URL-encode special characters in the password (@, #, etc.)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Supabase Auth / Storage ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Resend (Email) ---
RESEND_API_KEY=re_...

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Full origin of the deployed app (no trailing slash). On Vercel, set this to
# your production URL (e.g. https://locafleet.vercel.app) for Production,
# and to the preview URL pattern or the system $VERCEL_URL for Preview.
BETTER_AUTH_URL=http://localhost:3000

# --- App Config ---
# Same value as BETTER_AUTH_URL — exposed to the client for auth-client baseURL
# and outbound email links in server actions.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Seed Passwords (dev only — do NOT set on Vercel) ---
SEED_ADMIN_PASSWORD=
SEED_AGENT_PASSWORD=
SEED_VIEWER_PASSWORD=
